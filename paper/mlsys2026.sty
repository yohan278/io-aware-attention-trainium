\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{mlsys2026}[2026/03/09 Local MLSys-style formatting]

\RequirePackage[letterpaper,margin=0.75in,columnsep=0.25in,top=0.8in,bottom=1in]{geometry}
\RequirePackage{titlesec}
\RequirePackage{titling}
\RequirePackage{fancyhdr}
\RequirePackage{caption}

\setlength{\droptitle}{-0.6in}
\setlength{\parindent}{1em}
\setlength{\parskip}{0pt}
\setlength{\abovecaptionskip}{4pt}
\setlength{\belowcaptionskip}{0pt}

\titleformat{\section}{\large\bfseries}{\thesection}{0.5em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{0.5em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{0.5em}{}
\titlespacing*{\section}{0pt}{0.8em plus 0.2em minus 0.1em}{0.35em}
\titlespacing*{\subsection}{0pt}{0.65em plus 0.15em minus 0.1em}{0.25em}
\titlespacing*{\subsubsection}{0pt}{0.5em plus 0.15em minus 0.1em}{0.2em}

\pagestyle{fancy}
\fancyhf{}
\renewcommand{\headrulewidth}{0pt}
\cfoot{\thepage}

\pretitle{\begin{center}\LARGE\bfseries}
\posttitle{\par\end{center}\vspace{-0.5em}}
\preauthor{\begin{center}\normalsize}
\postauthor{\par\end{center}\vspace{-0.8em}}
\predate{\begin{center}\small}
\postdate{\par\end{center}\vspace{-1.0em}}

\captionsetup{font=small,labelfont=bf}
